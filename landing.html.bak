<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Play the Market</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&family=Roboto:wght@500&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            heading: ['Instrument Serif', 'serif'],
            body: ['Barlow', 'sans-serif'],
          },
          borderRadius: {
            DEFAULT: '9999px'
          },
          screens: {
            'xs': '475px',
          }
        }
      }
    }
  </script>
  <script src="https://unpkg.com/react@18.3.1/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js"></script>
  <style>
    body {
      background: #000;
      background: linear-gradient(135deg, #0a0a1a 0%, #000 100%);
      margin: 0;
      font-family: 'Barlow', sans-serif;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      -webkit-text-size-adjust: 100%;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    /* Hide all video control elements */
    video::-webkit-media-controls,
    video::-webkit-media-controls-enclosure,
    video::-webkit-media-controls-panel,
    video::-webkit-media-controls-play-button,
    video::-webkit-media-controls-timeline,
    video::-webkit-media-controls-current-time-display,
    video::-webkit-media-controls-time-remaining-display,
    video::-webkit-media-controls-mute-button,
    video::-webkit-media-controls-volume-slider,
    video::-webkit-media-controls-fullscreen-button,
    video::-webkit-media-controls-overflow-button,
    video::-webkit-media-controls-overlay,
    video::-webkit-media-controls-skip-button,
    video::-webkit-media-controls-rewind-button,
    video::-webkit-media-controls-return-to-realtime-button {
      display: none !important;
      opacity: 0 !important;
    }
    
    video {
      -webkit-appearance: none !important;
      -moz-appearance: none !important;
      appearance: none !important;
    }
    
    .liquid-glass {
      background: rgba(255,255,255,0.01);
      background-blend-mode: luminosity;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border: none;
      box-shadow: inset 0 1px 1px rgba(255,255,255,0.1);
      position: relative;
      overflow: hidden;
    }
    
    .liquid-glass::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1.4px;
      background: linear-gradient(180deg,
        rgba(255,255,255,0.45) 0%,
        rgba(255,255,255,0.15) 20%,
        rgba(255,255,255,0) 40%,
        rgba(255,255,255,0) 60%,
        rgba(255,255,255,0.15) 80%,
        rgba(255,255,255,0.45) 100%);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }
    
    .liquid-glass-strong {
      background: rgba(255,255,255,0.01);
      background-blend-mode: luminosity;
      backdrop-filter: blur(50px);
      -webkit-backdrop-filter: blur(50px);
      border: none;
      box-shadow: 4px 4px 4px rgba(0,0,0,0.05), inset 0 1px 1px rgba(255,255,255,0.15);
      position: relative;
      overflow: hidden;
    }
    
    .liquid-glass-strong::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1.4px;
      background: linear-gradient(180deg,
        rgba(255,255,255,0.5) 0%,
        rgba(255,255,255,0.2) 20%,
        rgba(255,255,255,0) 40%,
        rgba(255,255,255,0) 60%,
        rgba(255,255,255,0.2) 80%,
        rgba(255,255,255,0.5) 100%);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }
    
    /* Mobile touch improvements */
    @media (hover: none) and (pointer: coarse) {
      .liquid-glass:hover,
      .liquid-glass-strong:hover {
        background: rgba(255,255,255,0.02);
      }
    }
    
    /* Safe area support for mobile */
    @supports (padding: max(0px)) {
      nav {
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
      }
    }
  </style>
</head>
<body>
  <div id="root">
    <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;color:white;font-family:system-ui;background:#000">
      <p style="text-align:center">Loading...</p>
    </div>
  </div>

  <script type="text/babel">
    const { useState, useEffect, useRef } = React;
    
    // Icons
    const ArrowUpRight = ({ className = "" }) => (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
        <line x1="7" y1="17" x2="17" y2="7"></line>
        <line x1="7" y1="7" x2="17" y2="17"></line>
      </svg>
    );

    const Play = ({ className = "" }) => (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" className={className}>
        <polygon points="6 4 20 12 6 20 6 4"></polygon>
      </svg>
    );

    // Video Component - no controls, prevents saving
    function HeroVideo({ src, className = "", style = {} }) {
      const videoRef = useRef(null);
      
      useEffect(() => {
        const video = videoRef.current;
        if (!video) return;
        
        // Disable media session skip buttons
        if ('mediaSession' in navigator) {
          try {
            navigator.mediaSession.metadata = null;
            navigator.mediaSession.setActionHandler('skipforward', null);
            navigator.mediaSession.setActionHandler('skipbackward', null);
            navigator.mediaSession.setActionHandler('seekforward', null);
            navigator.mediaSession.setActionHandler('seekbackward', null);
            navigator.mediaSession.setActionHandler('previoustrack', null);
            navigator.mediaSession.setActionHandler('nexttrack', null);
          } catch (e) {
            console.log('MediaSession error:', e);
          }
        }
        
        video.muted = true;
        video.playsInline = true;
        video.loop = true;
        video.setAttribute('playsinline', 'true');
        video.setAttribute('webkit-playsinline', 'true');
        
        const handleLoadedData = () => {
          video.style.opacity = '1';
          video.play().catch(e => console.log('Video play failed:', e));
        };
        
        const handleError = () => {
          console.log('Video error');
        };
        
        video.addEventListener('loadeddata', handleLoadedData);
        video.addEventListener('error', handleError);
        
        return () => {
          video.removeEventListener('loadeddata', handleLoadedData);
          video.removeEventListener('error', handleError);
        };
      }, []);

      return (
        <video
          ref={videoRef}
          muted
          playsInline
          preload="auto"
          disablePictureInPicture
          controls={false}
          onContextMenu={(e) => e.preventDefault()}
          onDragStart={(e) => e.preventDefault()}
          onDoubleClick={(e) => e.preventDefault()}
          onKeyDown={(e) => e.preventDefault()}
          onKeyUp={(e) => e.preventDefault()}
          style={{
            ...style,
            opacity: 0,
            pointerEvents: 'none',
            userSelect: 'none',
            WebkitUserSelect: 'none',
            WebkitTouchCallout: 'none',
            outline: 'none',
            border: 'none',
            width: '100%',
            height: '100%',
            objectFit: 'cover',
            position: 'absolute',
            top: 0,
            left: 0
          }}
        >
          <source src={src} />
        </video>
      );
    }

    // Navbar Component
    function Navbar({ currentPage, setCurrentPage }) {
      const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
      
      return (
        <nav className="fixed top-4 left-0 right-0 px-4 xs:px-8 lg:px-16 z-50 flex items-center justify-between">
          <a href="#home" onClick={() => setCurrentPage('home')} className="liquid-glass rounded-full w-10 h-10 xs:w-12 xs:h-12 flex items-center justify-center overflow-hidden">
            <img src="/logo.png" alt="Logo" className="w-full h-full object-cover" />
          </a>
          <div className="hidden md:flex liquid-glass rounded-full px-2 py-1.5 items-center gap-1">
            {['Home', 'Privacy Policy', 'Sign Up'].map(item => (
              <a 
                key={item} 
                href={`#${item.toLowerCase().replace(/\s+/g, '-')}`} 
                onClick={() => setCurrentPage(item.toLowerCase().replace(/\s+/g, '-'))}
                className="px-3 py-2 text-sm font-medium text-white/90 font-body hover:text-white transition-colors"
              >
                {item}
              </a>
            ))}
          </div>
          <button 
            className="md:hidden liquid-glass rounded-full w-10 h-10 xs:w-12 xs:h-12 flex items-center justify-center"
            onClick={() => setMobileMenuOpen(!mobileMenuOpen)}
            aria-label="Toggle menu"
          >
            <svg className="w-5 h-5 xs:w-6 xs:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              {mobileMenuOpen ? (
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
              ) : (
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16M4 18h16" />
              )}
            </svg>
          </button>
          
          {/* Mobile Menu */}
          {mobileMenuOpen && (
            <div className="md:hidden absolute top-full left-4 right-4 mt-2 liquid-glass rounded-2xl p-4">
              {['Home', 'Privacy Policy', 'Sign Up'].map(item => (
                <a 
                  key={item} 
                  href={`#${item.toLowerCase().replace(/\s+/g, '-')}`} 
                  onClick={() => {
                    setCurrentPage(item.toLowerCase().replace(/\s+/g, '-'));
                    setMobileMenuOpen(false);
                  }}
                  className="block px-4 py-3 text-base font-medium text-white/90 font-body hover:text-white transition-colors border-b border-white/10 last:border-0"
                >
                  {item}
                </a>
              ))}
            </div>
          )}
        </nav>
      );
    }

    // Hero Section
    function HeroSection() {
      return (
        <section className="min-h-screen relative bg-black">
          <HeroVideo
            src="/bg.mp4"
            className="absolute inset-0 w-full h-full z-0 pointer-events-none"
          />
          
          <Navbar currentPage="home" setCurrentPage={() => {}} />
          
          <div className="relative z-10 min-h-screen flex flex-col pt-20 px-4 pointer-events-none">
            <div className="flex-1 flex flex-col items-center justify-center max-w-4xl mx-auto pointer-events-auto">
              <div className="liquid-glass rounded-full px-2.5 py-0.5 xs:px-3 xs:py-1 flex items-center gap-1.5 xs:gap-2 mb-8 xs:mb-12">
                <span className="bg-white text-black px-2 py-0.5 xs:px-3 xs:py-1 rounded-full text-2xs xs:text-xs font-semibold">New</span>
                <span className="text-2xs xs:text-sm text-white/90 font-body pr-2 xs:pr-3">New Stock Simulator v2.0 Live Now</span>
              </div>

              <h1 className="text-4xl xs:text-5xl md:text-7xl lg:text-[5.5rem] font-heading italic text-white leading-[0.8] max-w-2xl justify-center tracking-[-2px] xs:tracking-[-4px] mb-6 xs:mb-8">
                Master the Market
              </h1>

              <p className="mt-4 text-xs xs:text-sm md:text-base text-white max-w-2xl font-body font-light leading-tight px-2">
                Experience stock market mastery with cutting-edge simulations. Our platform delivers real-world trading scenarios, expert insights, and advanced analytics to help you navigate the markets with confidence.
              </p>

              <div className="flex flex-col xs:flex-row items-center gap-3 xs:gap-6 mt-6 w-full xs:w-auto">
                <a href="#sign-up" className="text-sm text-white font-body hover:underline w-full xs:w-auto text-center">Sign In</a>
                <a href="https://play.google.com/store/apps/details?id=com.virionplaysgg.stokk&hl=en" target="_blank" rel="noopener noreferrer" className="liquid-glass rounded-full px-5 py-2.5 text-sm font-medium text-white inline-block w-full xs:w-auto text-center">
                  Download
                </a>
              </div>
            </div>
          </div>
        </section>
      );
    }

    // Stock Simulations Section
    function StockSimulationsSection() {
      return (
        <section className="min-h-screen relative bg-black flex items-center justify-center">
          <div className="relative z-10 px-4 md:px-16 lg:px-20 py-16 md:py-24 text-center">
            <h2 className="font-heading italic text-white text-4xl xs:text-5xl md:text-7xl lg:text-[6rem] leading-[0.9] tracking-[-2px] xs:tracking-[-3px] mb-8">
              <span className="block">Stock simulations</span>
              <span className="block text-3xl xs:text-4xl md:text-6xl lg:text-7xl tracking-[-1px] xs:tracking-[-2px]">has <span className="text-white/60">changed</span> have you?</span>
            </h2>
            <a 
              href="https://play.google.com/store/apps/details?id=com.virionplaysgg.stokk&hl=en" 
              target="_blank" 
              rel="noopener noreferrer"
              className="inline-flex items-center gap-2 md:gap-3 liquid-glass-strong rounded-full px-6 py-3 md:px-8 md:py-4 text-base md:text-lg font-medium text-white hover:text-white transition-colors w-full xs:w-auto justify-center"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" className="md:w-6 md:h-6" fill="currentColor" viewBox="0 0 16 16">
                <path d="M14.222 9.374c1.037-.61 1.037-2.137 0-2.748L11.528 5.04 8.32 8l3.207 2.96zm-3.595 2.116L7.583 8.68 1.03 14.73c.201 1.029 1.36 1.61 2.303 1.055zM1 13.396V2.603L6.846 8zM1.03 1.27l6.553 6.05 3.044-2.81L3.333.215C2.39-.341 1.231.24 1.03 1.27"/>
              </svg>
              Download on the Play Store
            </a>
          </div>
        </section>
      );
    }

    // Auth Section
    function AuthSection({ setCurrentPage }) {
      const [isSignUp, setIsSignUp] = useState(true);
      const [email, setEmail] = useState('');
      const [password, setPassword] = useState('');

      const handleSubmit = (e) => {
        e.preventDefault();
        console.log('Auth submitted:', { isSignUp, email, password });
        alert(`${isSignUp ? 'Sign Up' : 'Sign In'} functionality would connect to backend`);
      };

      return (
        <section className="min-h-screen relative bg-black flex items-center justify-center pt-20">
          <Navbar currentPage="sign-up" setCurrentPage={setCurrentPage} />
          <div className="relative z-10 w-full max-w-sm mx-4 sm:max-w-md px-4">
            <div className="liquid-glass rounded-[1.5rem] p-6 sm:p-8">
              <h2 className="font-heading italic text-white text-3xl sm:text-4xl mb-4 sm:mb-6 text-center">
                {isSignUp ? 'Create Account' : 'Welcome Back'}
              </h2>
              
              <form onSubmit={handleSubmit} className="space-y-3 sm:space-y-4">
                <div>
                  <input
                    type="email"
                    placeholder="Email"
                    value={email}
                    onChange={(e) => setEmail(e.target.value)}
                    className="w-full px-4 py-3 rounded-full bg-white/10 text-white placeholder-white/50 font-body focus:outline-none focus:bg-white/15 transition-colors text-base"
                    required
                  />
                </div>
                <div>
                  <input
                    type="password"
                    placeholder="Password"
                    value={password}
                    onChange={(e) => setPassword(e.target.value)}
                    className="w-full px-4 py-3 rounded-full bg-white/10 text-white placeholder-white/50 font-body focus:outline-none focus:bg-white/15 transition-colors text-base"
                    required
                  />
                </div>
                <button
                  type="submit"
                  className="w-full liquid-glass-strong rounded-full py-3 font-medium text-white font-body text-base"
                >
                  {isSignUp ? 'Sign Up' : 'Sign In'}
                </button>

                <div className="relative py-4">
                  <div className="absolute inset-0 flex items-center"><span className="w-full border-t border-white/10"></span></div>
                  <div className="relative flex justify-center text-[10px] uppercase tracking-[0.2em]"><span className="bg-[#050505] px-3 text-white/30 font-body">Or continue with</span></div>
                </div>

                <button
                  type="button"
                  onClick={() => window.location.href = '/api/auth/signin/google'}
                  className="group relative flex h-12 w-full items-center justify-center gap-3 overflow-hidden rounded-full bg-white text-black transition-all hover:bg-[#f2f2f2] border border-[#dadce0]"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.05H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.05l3.66 2.84c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
                  </svg>
                  <span style={{ fontFamily: "'Roboto', sans-serif", fontSize: "14px", fontWeight: "500", color: "#1f1f1f", letterSpacing: "0.2px" }}>Sign in with Google</span>
                </button>
              </form>
              
              <p className="text-center text-white/70 text-sm mt-3 sm:mt-4 font-body">
                {isSignUp ? 'Already have an account?' : "Don't have an account?"}{' '}
                <button
                  onClick={() => setIsSignUp(!isSignUp)}
                  className="text-white font-medium hover:underline"
                >
                  {isSignUp ? 'Sign In' : 'Sign Up'}
                </button>
              </p>
            </div>
          </div>
        </section>
      );
    }

    // Privacy Policy Section
    function PrivacyPolicySection({ setCurrentPage }) {
      return (
        <section className="min-h-screen relative bg-black pt-20">
          <Navbar currentPage="privacy-policy" setCurrentPage={setCurrentPage} />
          <div className="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 md:px-8 py-12 sm:py-16 md:py-20">
            <h2 className="font-heading italic text-white text-4xl sm:text-5xl md:text-6xl mb-6 sm:mb-8">
              Privacy Policy
            </h2>
            
            <div className="liquid-glass rounded-[1.5rem] p-4 sm:p-6 md:p-8 space-y-4 sm:space-y-6">
              <div>
                <h3 className="font-heading italic text-white text-lg sm:text-xl mb-2 sm:mb-3">Information We Collect</h3>
                <p className="text-white/80 font-body leading-relaxed text-sm sm:text-base">
                  We collect information you provide directly to us, including your email address, 
                  password, and any other information you choose to share when creating an account.
                </p>
              </div>
              
              <div>
                <h3 className="font-heading italic text-white text-lg sm:text-xl mb-2 sm:mb-3">How We Use Your Information</h3>
                <p className="text-white/80 font-body leading-relaxed text-sm sm:text-base">
                  We use the information we collect to provide, maintain, and improve our services, 
                  including to authenticate your account, communicate with you, and personalize your experience.
                </p>
              </div>
              
              <div>
                <h3 className="font-heading italic text-white text-lg sm:text-xl mb-2 sm:mb-3">Data Security</h3>
                <p className="text-white/80 font-body leading-relaxed text-sm sm:text-base">
                  We implement security measures to protect your personal information. Your password 
                  is encrypted and stored securely using industry-standard practices.
                </p>
              </div>
              
              <div>
                <h3 className="font-heading italic text-white text-lg sm:text-xl mb-2 sm:mb-3">Contact Us</h3>
                <p className="text-white/80 font-body leading-relaxed text-sm sm:text-base">
                  If you have questions about this Privacy Policy, please contact us at privacy@example.com.
                </p>
              </div>
            </div>
          </div>
        </section>
      );
    }

    // Main App with page routing
    function App() {
      const [currentPage, setCurrentPage] = useState('home');

      useEffect(() => {
        const handleHashChange = () => {
          const hash = window.location.hash.slice(1) || 'home';
          setCurrentPage(hash);
        };
        window.addEventListener('hashchange', handleHashChange);
        handleHashChange();
        return () => window.removeEventListener('hashchange', handleHashChange);
      }, []);

      return (
        <>
          {currentPage === 'home' && (
            <>
              <HeroSection />
              <StockSimulationsSection />
            </>
          )}
          {currentPage === 'sign-up' && <AuthSection setCurrentPage={setCurrentPage} />}
          {currentPage === 'privacy-policy' && <PrivacyPolicySection setCurrentPage={setCurrentPage} />}
        </>
      );
    }

    // Simple render check - wait for React only
    function initApp() {
      console.log('Checking for React...');
      
      if (window.React && window.ReactDOM) {
        console.log('React loaded, rendering...');
        try {
          ReactDOM.createRoot(document.getElementById('root')).render(<App />);
        } catch (err) {
          console.error('Failed to render app:', err);
          document.getElementById('root').innerHTML = '<div style="padding:20px;color:white">Error: ' + err.message + '</div>';
        }
      } else {
        setTimeout(initApp, 100);
      }
    }

    // Start after DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initApp);
    } else {
      initApp();
    }
  </script>
</body>
</html>
